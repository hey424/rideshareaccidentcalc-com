---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Methodology | rideshareaccidentcalc.com';
const description = 'How the rideshare accident calculator works: pain multipliers by severity and insurance phase limits.';
---
<BaseLayout title={title} description={description}>
  <h1>Methodology</h1>
  <p><em>Reviewed by Aspen Lockwood (AL), Editor-in-Chief. Updated May 2026.</em></p>
  <h2>Pain and suffering multipliers</h2><p>Same as standard personal injury: catastrophic 7×, severe 5×, moderate 3.5×, minor 2× medical costs, plus 2× lost wages.</p>
  <h2>Insurance phase caps</h2><p>Period 2/3: $1,000,000. Period 1: $100,000. Period 0: $50,000 (estimated personal policy minimum). The calculator caps the estimated recovery at the applicable limit because exceeding policy limits requires suing the driver personally — more difficult and uncertain recovery.</p>
</BaseLayout>
