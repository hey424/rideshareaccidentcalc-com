---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Contact | rideshareaccidentcalc.com';
const description = 'Contact the editorial team at rideshareaccidentcalc.com with corrections, feedback, or questions about rideshare accident claims content.';
---
<BaseLayout title={title} description={description}>
  <h1>Contact</h1>
  <p>For corrections, feedback, or questions about our content, email <a href="mailto:hey@theclicklab.agency">hey@theclicklab.agency</a>.</p>

  <h2>What We Can Help With</h2>
  <ul>
    <li><strong>Corrections:</strong> If you find an error — wrong coverage amount, outdated phase limit, incorrect legal standard, misstated state rule — let us know with a description of the error and a reference to the correct authority.</li>
    <li><strong>Feedback:</strong> Suggestions for guides we should add, calculator features, or topics we haven't covered.</li>
    <li><strong>Media:</strong> Reporters or researchers referencing our methodology or guides are welcome to reach out.</li>
  </ul>

  <h2>What We Can't Help With</h2>
  <p>We are not able to provide legal advice or case-specific guidance. We are an editorial resource, not a law firm. For help with an actual rideshare accident claim, consult a licensed personal injury attorney — most handle rideshare cases on contingency with free initial consultations.</p>

  <p>Typical response time: 2–5 business days.</p>
</BaseLayout>
